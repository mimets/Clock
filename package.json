{
  "name": "stage-tracker",
  "version": "1.0.65",
  "description": "Stage Tracker - traccia il tuo stage",
  "author": "Federico <mimets@github>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node scripts/make-icon.mjs && node scripts/patch-nsis.mjs",
    "build": "electron-builder --win --x64",
    "release": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.stagetracker.app",
    "productName": "Stage Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "manifest.json",
      "icon-192.svg",
      "icon-512.svg",
      "icon.png",
      "sw.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "sign": null,
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "artifactName": "StageTracker-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "include": "nsis-override.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "mimets",
      "repo": "Clock",
      "private": false,
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "pg": "^8.21.0"
  }
}